# Optional VHS tape for deepread (EN). Prefer: python3 ../render_demos.py
Output ../../assets/demos/deepread.en.mp4
Set FontSize 16
Set Width 960
Set Height 560
Set Theme "Catppuccin Mocha"
Set TypingSpeed 28ms
Set Framerate 20
Type "# See website/demos/scenes.json — render with python3 render_demos.py"
Enter
Sleep 1500ms
