# =============================================================================
# 模型服务配置 — 复制为 model_servers.yaml 后编辑
# cp config/model_servers.yaml.example config/model_servers.yaml
# =============================================================================
#
# 列表顺序 = auto 模式默认优先级（可用 .env 中 LA_MODEL_PROVIDER_PRIORITY 覆盖）
#
# 通用字段（OpenAI 兼容 API）:
#   provider   唯一标识，小写字母/数字/下划线/连字符
#   base_url   API 根路径，如 https://aiping.cn/api/v1
#   api_key    API Key（含敏感信息，勿提交 Git）
#   model      模型名称
#   timeout    请求超时秒数，默认 120
#
# ollama 专用: think, num_predict, num_ctx, keep_alive, chat_timeout, chat_stream
# cursor 专用: cwd, max_retries
#
# 说明: ollama.model 为推荐默认值。若本机未安装该模型但已有其他对话模型，
# LA 会自动改用已安装/已加载的模型，不会强制拉取。

- provider: ollama
  base_url: http://localhost:11434
  model: qwen3.5:4b
  timeout: 90
  think: false
  # 512 对工具后综合回答偏紧，易截成「根据」；本地小模型建议 ≥2048
  num_predict: 2048
  num_ctx: 8192
  keep_alive: 30m
  # auto 首包超时（秒）；也可用 .env 的 LA_OLLAMA_CHAT_TIMEOUT 覆盖
  chat_timeout: 12
  chat_stream: true

# - provider: aiping
#   base_url: https://aiping.cn/api/v1
#   api_key: ""
#   model: GLM-5.2
#   timeout: 30

- provider: openai
  base_url: https://api.openai.com/v1
  api_key: ""
  model: gpt-4o-mini
  timeout: 120

- provider: openrouter
  base_url: https://openrouter.ai/api/v1
  api_key: ""
  model: anthropic/claude-sonnet-4
  timeout: 120

- provider: cursor
  api_key: ""
  model: composer-2.5
  timeout: 120
  max_retries: 2
