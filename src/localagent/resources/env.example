# =============================================================================
# LocalAgent 配置 — 复制此文件为 .env 并按需修改
# cp .env.example .env
# =============================================================================

# --- 模型服务（推荐：独立 YAML 文件，易读易改）---
# 首次运行 LA 时会自动从 config/model_servers.yaml.example 创建配置文件
# 编辑: config/model_servers.yaml（列表顺序 = auto 优先级）
LA_MODEL_SERVERS_FILE=config/model_servers.yaml

# 可选：覆盖默认优先级（不设置则按 YAML 列表顺序）
# LA_MODEL_PROVIDER_PRIORITY=ollama,aiping,openrouter

# --- 兼容：内联 JSON（不推荐，难维护）---
# LA_MODEL_SERVERS=[{"provider":"ollama",...}]

# --- Web search ---
# auto（默认）: 有 TAVILY_API_KEY → Tavily；否则有 LA_SEARXNG_URL → SearXNG；否则 ddgs（免费、无需 Key）
# LA_WEB_SEARCH_PROVIDER=auto   # auto | ddgs | tavily | searxng
# LA_SEARXNG_URL=http://localhost:8080
# LA config set-key tavily <key>
TAVILY_API_KEY=

# --- Workspace context (git / recent files / todos) ---
# LA_WORKSPACE=/path/to/your/project

# --- Agent shell tool (run_shell) ---
# LA_SHELL_TIMEOUT=30
# LA_SHELL_MAX_OUTPUT=12000
# 工具审批：always=每次 run_shell/write_file 都确认（默认）；
# dangerous=仅危险命令/写文件确认；off=关闭（不推荐）
# LA_TOOL_APPROVAL=always
# Observe 启发式压缩（本地小模型上下文预算；不额外调 LLM）
# LA_OBSERVE_BUDGET_CHARS=1200
# LA_PREFETCH_BUDGET_CHARS=1500
# LA_OBSERVE_KEEP_HITS=6
# STM 滚动窗（小时）：今天/刚才类问句预取近窗内对话；默认 24
# LA_STM_WINDOW_HOURS=24

# --- Audit cost estimates (USD; optional overrides) ---
# LA_COST_MINIMAX_PER_M=1.0
# LA_COST_OPENROUTER_PER_M=3.0
# LA_COST_CURSOR_PER_CALL=0.05
# LA_COST_TAVILY_PER_CALL=0.01

# --- Retrieval tuning ---
LA_SEMANTIC_WEIGHT=0.75
LA_TIME_HALFLIFE_DAYS=90
# LA_RECENCY_HALFLIFE_DAYS=14
# LA_MEMORY_SCOPE_NEAR_DAYS=30
# LA_MEMORY_RECALL_HYBRID=1
# LA_MEMORY_RECALL_QUERY_EXPAND=1
# LA_MEMORY_RECALL_DECOMPOSE=1
# LA_MEMORY_RECALL_DECOMPOSE_MAX=3
# LA_MEMORY_RECALL_VECTOR_VARIANTS=2
# LA_MEMORY_RECALL_ENTITY_BOOST=1
# LA_MEMORY_RECALL_CLASS_BOOST=1   # semantic/episodic/procedural 与查询意图软对齐
# LA_MEMORY_CLASS_WEIGHT=0.10
# --- Optional Warm relation graph (DEFAULT OFF; capability retained) ---
# Storage is a local SQLite file (data/memory_graph.db) — light on disk.
# Cost is mainly recall latency (extra CE pass when enabled). Day-to-day gains
# are small vs hybrid+cross-encoder; leave at 0 unless experimenting on multi-hop.
# LA_MEMORY_GRAPH=0
# LA_MEMORY_GRAPH_HOPS=2
# LA_MEMORY_GRAPH_BOOST=0           # graph does not boost hybrid score (pool-only)
# LA_MEMORY_GRAPH_MAX_EXTRAS=8
# LA_MEMORY_GRAPH_PROTECT_TOP=1     # pin seed-only top-N after expand (Hit@1 stable)
# LA_MEMORY_GRAPH_FORCE_IN_TOP=3    # force-insert graph extras after protected prefix
# After enabling: LA memory graph rebuild
# Docs: README.en「Optional Warm relation graph」/ README「可选 Warm 关系图」

# --- Optional Neo4j precise queries (off by default) ---
# Counts / aggregations / formal multi-hop → Cypher computed results (not text sampling).
# Independent of LA_MEMORY_GRAPH. pip install 'la-localagent[neo4j]'
# LA_NEO4J=0
# LA_NEO4J_URI=bolt://localhost:7687
# # or in-process: LA_NEO4J_URI=memory://
# LA_NEO4J_USER=neo4j
# LA_NEO4J_PASSWORD=password
# LA_NEO4J_DATABASE=neo4j
# LA_NEO4J_TEXT2CYPHER=0
# After enabling: LA memory graph neo4j rebuild
# Query: LA memory graph query "how many times was Caroline mentioned?"

# LA_MEMORY_RERANK=1
# LA_MEMORY_RERANK_BACKEND=auto   # auto|cross_encoder|embed|llm|off — prefer cross_encoder with graph
# LA_MEMORY_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# LA_MEMORY_RERANK_CANDIDATES=24
# LA_MEMORY_RECALL_NEIGHBOR_WINDOW=0
# LA_MEMORY_RECALL_WHEN_EVENT_NEIGHBOR_WINDOW=1

# --- Ingest memory (add-file / sync-file) ---
# LA_INGEST_USE_LLM=0
# LA_INGEST_MEMORY_MAX_CHARS=1500
# LA_INGEST_MEMORY_MAX_FACTS=50
# LA_INGEST_WARM_SUMMARY=1          # 长文档写 Warm 摘要（Cold 仍索引全文）
# LA_INGEST_SUMMARY_MIN_CHARS=800
# LA_INGEST_SUMMARY_MAX_SECTIONS=8
# LA_MEMORY_SUMMARY_MAX_CHARS=600
# LA_MEMORY_SUMMARY_USE_LLM=0
# LA_MEMORY_SESSION_SUMMARY=1       # 会话结束写 session 摘要记忆
# LA_MEMORY_REFLECT_MAX_HOPS=2      # reflect 最多补充检索轮数
# LA_MEMORY_REFLECT_TOP_K=8
# LA_MEMORY_CONSOLIDATE=1           # 写时巩固 ADD/UPDATE/DELETE
# LA_MEMORY_CONSOLIDATE_ON_MEMORIZE=1
# LA_MEMORY_CONSOLIDATE_RELATED_K=5
# LA_MEMORY_APPROVAL_REQUIRED=1     # 退出提取/导入：非交互入队待确认（LA memory pending）
# LA_MEMORY_APPROVAL_AUTO=0         # 1=跳过确认门直接写入 Warm（CI/基准）

# --- Memory enrichment (title / tags / summary) ---
# LA_MEMORY_ENRICH_LLM=0
# LA_MEMORY_BACKEND=mem0           # mem0 | json
# MEM0_TELEMETRY=False             # 默认关闭 Mem0→PostHog 遥测；设为 True 才开启
# LA_MEM0_INFER=0                  # 1=让 Mem0 LLM 再抽事实（更慢）；默认 0，由 LA enrich 负责
# LA_MEM0_RETAIN_JSON_FALLBACK=1   # retain 失败时写入 JSON，避免 import 中断
# LA_MEM0_LLM_PROVIDER=            # ollama | openai | openrouter（默认跟随 ModelRouter）
# LA_MEM0_LLM_MODEL=
# LA_MEM0_LLM_BASE_URL=
# LA_MEM0_LLM_API_KEY=
# LA_MEM0_EMBEDDER_PROVIDER=       # ollama | openai | openrouter（默认自动选 Ollama 嵌入模型）
# LA_MEM0_EMBEDDER_MODEL=          # 如 bge-m3 / nomic-embed-text / text-embedding-3-small
# LA_MEM0_EMBEDDER_BASE_URL=
# LA_MEM0_EMBEDDER_API_KEY=
# LA_MEM0_EMBEDDER_DIMS=0          # 0=按模型名推断

# --- Data directory override (tests / isolation) ---
# LA_DATA_DIR=/path/to/custom/data

# --- Diagnostic logging (troubleshooting; not audit) ---
# LA_LOG_LEVEL=INFO              # INFO（默认）| DEBUG | WARNING | ERROR
# 开发盯终端: LA --debug <command> 或 LA_LOG_LEVEL=DEBUG（DEBUG 时同步打 stderr）
# 查看: LA logs [--tail 80] [--level WARNING] [--path]
