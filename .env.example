# Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
# Qwen3 等模型默认会生成大量 thinking token，导致 chat 极慢；保持 0 关闭
OLLAMA_THINK=0
# OLLAMA_NUM_PREDICT=512
# OLLAMA_NUM_CTX=4096
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_TIMEOUT=90
# LA_OLLAMA_CHAT_TIMEOUT=12
# OLLAMA_CHAT_STREAM=1

# Fallback models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# auto 模式下的模型路径优先级（逗号分隔）
LA_MODEL_PROVIDER_PRIORITY=ollama,openrouter,cursor

# Web search (Tavily)
TAVILY_API_KEY=

# Workspace context (git / recent files / todos)
# LA_WORKSPACE=/path/to/your/project

# Audit cost estimates (USD; optional overrides)
# LA_COST_OPENROUTER_PER_M=3.0
# LA_COST_CURSOR_PER_CALL=0.05
# LA_COST_TAVILY_PER_CALL=0.01

# Retrieval tuning
LA_SEMANTIC_WEIGHT=0.75
LA_TIME_HALFLIFE_DAYS=90

# Ingest memory (add-file / sync-file): heuristic by default, no LLM
# LA_INGEST_USE_LLM=1              # enable LLM fact extraction (slow on long docs)
# LA_INGEST_MEMORY_MAX_CHARS=1500   # skip long sections for memory (RAG still indexes all)
# LA_INGEST_MEMORY_MAX_FACTS=50     # cap memory facts per file

# Memory enrichment at write time (title / tags / summary; Mem0 & Hindsight pattern)
# LA_MEMORY_ENRICH_LLM=1           # use LLM for title/tags/summary (slower, higher quality)
